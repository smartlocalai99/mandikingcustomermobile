{
  "expo": {
    "name": "smartrestaimobile",
    "slug": "smartrestaimobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "smartrestaimobile",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smartrestai.SmartRestAI",
      "infoPlist": {
        "NSFaceIDUsageDescription": "SmartRest uses Face ID to quickly and securely verify it's you when you log in."
      }
    },
    "android": {
      "package": "com.smartrestai.smartrestaimobile",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-image",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#32120d",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SmartRest uses your location to suggest a delivery address. You can enter one manually instead."
        }
      ],
      "expo-font",
      "expo-audio",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "79b163a0-e688-47a4-ac04-b185a67ecc18"
      }
    },
    "owner": "vardhanreddy"
  }
}
